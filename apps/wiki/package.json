{
	"name": "@inf-uct/code-lens-wiki",
	"version": "1.0.0",
	"description": "CLI tool for Code Lens",
	"main": "dist/index.js",
	"bin": {
		"code-lens": "dist/main.js"
	},
	"scripts": {
		"build": "tsc",
		"start": "tsx --clear-screen=false src/main.ts",
		"watch": "tsx watch --clear-screen=false src/main.ts",
		"format": "prettier --write . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
		"format:check": "prettier --check . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
		"lint": "eslint src --ext .ts",
		"lint:fix": "eslint src --ext .ts --fix"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/INF-UCT/code-lens.git"
	},
	"keywords": [],
	"author": "Luciano Revillod <lrevillod2022@alu.uct.cl>",
	"license": "MIT",
	"type": "module",
	"bugs": {
		"url": "https://github.com/INF-UCT/code-lens-cli/issues"
	},
	"homepage": "https://github.com/INF-UCT/code-lens-cli#readme",
	"dependencies": {
		"@browserbasehq/stagehand": "^1.14.0",
		"@hono/node-server": "^1.19.9",
		"@langchain/community": "^1.1.22",
		"@langchain/core": "^1.1.31",
		"@langchain/openai": "^1.2.12",
		"@langchain/qdrant": "^1.0.1",
		"fast-glob": "^3.3.3",
		"hono": "^4.11.9",
		"langchain": "^1.2.18",
		"openai": "^4.104.0",
		"tree-sitter": "0.21.1",
		"tree-sitter-c": "0.21.4",
		"tree-sitter-cpp": "0.23.4",
		"tree-sitter-go": "0.23.4",
		"tree-sitter-java": "0.23.5",
		"tree-sitter-javascript": "0.23.1",
		"tree-sitter-python": "0.23.2",
		"tree-sitter-rust": "0.21.0",
		"tree-sitter-typescript": "0.23.2",
		"ts-pattern": "^5.9.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"@types/node": "^22.10.1",
		"eslint": "^9.15.0",
		"prettier": "^3.4.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.17.0"
	}
}
